{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "package.json", "tsconfig.json"],
      "outputs": ["dist/**"]
    },
    "test": {
      "inputs": ["src/**", "tests/**"]
    },
    "typecheck": {
      "inputs": ["src/**", "tests/**", "tsconfig.json", "tsconfig.test.json"]
    },
    "lint": {
      "inputs": ["src/**"]
    },
    "clean": {
      "cache": false
    },
    "package": {
      "dependsOn": ["build"],
      "outputs": ["*.vsix"]
    }
  }
}
